<div id="create_post_modal" class="modal">
  <div class="modal-content modal_create_post">
    <span class="close" id="close_create_post_modal">&times;</span>
    <div class="title">
      <h4>Tạo nhóm mới</h4>
    </div>
    <div class="auth">
      <div class="avatar">
        <%= image_tag('ava1.jpg') %>
      </div>
      <div class="name">
        <h3><%= current_user.name ? current_user.name : 'người dùng facebook' %></h3>
      </div>
    </div>
    <%= form_with model: group do |form| %>
      <%= form.label "Chọn chế độ của nhóm"%>
      <%= form.select :mode, Post.modes.keys.to_a %>
      <%= form.text_field :name, placeholder: "Tên nhóm" %>
      <div class="upload">
        thêm ảnh đại diện cho nhóm của bạn
        <label for="group_avatar"><%= image_tag('img_icon.png') %></label>
        <%= form.file_field :avatar, accept:'image/*' %>
      </div>
      <button class="button_wrap" type="submit">Đăng</button>
    <% end %>
  </div>
</div>
