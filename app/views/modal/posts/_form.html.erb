<div id="create_post_modal" class="modal">
  <div class="modal-content modal_create_post">
    <span class="close" id="close_create_post_modal">&times;</span>
    <div class="title">
      <h4>Tạo bài viết</h4>
    </div>
    <div class="auth">
      <div class="avatar">
        <%= image_tag('ava1.jpg') %>
      </div>
      <div class="name">
        <div class="item">
          <%= current_user.name ? current_user.name : 'người dùng facebook' %>
        </div>
      </div>
    </div>
    <%= form_with model: post do |form| %>
      <%= form.label "Chọn chế độ của bài viết"%>
      <%= form.select :mode, Post.modes.keys.to_a %>
      <%= form.text_area(:text, placeholder: "#{current_user.name} ơi, bạn đang nghĩ gì thế?" ) %>
      <%= form.hidden_field :group_id, value: group && group.id %>
      <%= form.hidden_field :in_queue, value: !(group && group.user_id === current_user.id) %>
      <div class="upload">
        Thêm ảnh đại diện cho nhóm
        <label for="post_content"><%= image_tag('img_icon.png') %></label>
        <%= form.file_field :content, accept:'image/*' %>
      </div>
      <button class="button_wrap" type="submit">Đăng</button>
    <% end %>
  </div>
</div>
